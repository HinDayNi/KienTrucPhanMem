<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lỗi hệ thống</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <h1><%= message %></h1>
  <h2>Mã lỗi: <%= error.status || 500 %></h2>
  <% if (error && error.stack) { %>
    <pre><%= error.stack %></pre>
  <% } %>
</body>
</html>
