# ===========================================================================
# Movie Ticket System - shared env
# Copy file này thành `.env` ở root repo. docker compose sẽ tự nạp.
# ===========================================================================
# Áp dụng cho 3 mode:
#   1. All-in-Docker     -> docker compose up -d --build
#      (DB_HOST/RABBITMQ_HOST trong .env KHÔNG dùng vì compose override = postgres / rabbitmq)
#   2. Dev mode          -> docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d
#   3. Hybrid local      -> chạy infra qua docker, các service chạy local bằng `mvn spring-boot:run`
#      (lúc này DB_HOST=localhost, RABBITMQ_HOST=localhost cho service local)
# ===========================================================================

# ---- JWT ----
# >= 32 bytes. PHẢI giống nhau giữa các service đọc/decode token.
# Thay đổi trước khi deploy production.
JWT_SECRET=change-me-in-production-please-use-at-least-32-bytes-long-secret-key
JWT_EXPIRES_IN_SECONDS=3600

# ---- PostgreSQL ----
# Khi chạy all-in-docker, DB_HOST sẽ bị compose override = "postgres" (service name).
# Khi service Spring Boot chạy LOCAL (mode hybrid) thì cần DB_HOST=localhost.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=movieticket
DB_PASSWORD=movieticket

# ---- RabbitMQ ----
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=movieticket
RABBITMQ_PASSWORD=movieticket

# ---- Frontend (Vite build-time variable) ----
# - Prod docker (Nginx): bỏ qua biến này, build với "" để dùng URL tương đối + nginx proxy /api.
# - Dev docker (Vite):   docker-compose.dev.yml set "http://localhost:8080" tự động.
# - Local dev (npm run dev ngoài docker): dùng giá trị bên dưới.
VITE_API_GATEWAY_URL=http://localhost:8080

# ---- Payment Service ----
# Tỉ lệ thanh toán thành công (0.0 - 1.0). Để 0.7 cho demo có cả CONFIRMED lẫn FAILED.
PAYMENT_SUCCESS_RATE=0.7

# ---- Service-to-service URLs (api-gateway routing) ----
# Compose tự override các giá trị bên dưới = http://<service-name>:<port>.
# Để cho mode hybrid khi gateway chạy ngoài docker và muốn trỏ tới LAN host khác.
# USER_SERVICE_URL=http://localhost:8081
# MOVIE_SERVICE_URL=http://localhost:8082
# BOOKING_SERVICE_URL=http://localhost:8083
